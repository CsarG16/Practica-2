@model IEnumerable<Practica_2.Models.Curso>

@{
    ViewData["Title"] = "Panel de Coordinador";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2 class="mb-0 text-danger fw-bold">
            <i class="bi bi-shield-lock me-2"></i>Panel del Coordinador
        </h2>
        <a asp-action="CrearCurso" class="btn btn-primary shadow-sm rounded-pill px-4">
            <i class="bi bi-plus-circle me-2"></i>Crear Nuevo Curso
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">Código</th>
                            <th>Nombre del Curso</th>
                            <th>Créditos</th>
                            <th>Horario</th>
                            <th>Cupo</th>
                            <th>Estado</th>
                            <th class="text-center pe-4">Acciones Administrativas</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5 text-muted">
                                    <i class="bi bi-folder-x fs-1 d-block mb-3"></i>
                                    No hay cursos registrados en el sistema.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-secondary">@item.Codigo</td>
                                    <td class="fw-bold">@item.Nombre</td>
                                    <td>@item.Creditos</td>
                                    <td>
                                        <i class="bi bi-clock me-1 text-muted"></i>
                                        @item.HorarioInicio.ToString(@"hh\:mm") - @item.HorarioFin.ToString(@"hh\:mm")
                                    </td>
                                    <td>
                                        <i class="bi bi-people me-1 text-muted"></i> @item.CupoMaximo
                                    </td>
                                    <td>
                                        @if (item.Activo)
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill">Activo</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary px-3 py-2 rounded-pill">Inactivo</span>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            
                                            <a asp-action="EditarCurso" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Editar curso">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <a asp-action="Matriculas" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info" title="Gestionar Matrículas">
                                                <i class="bi bi-card-checklist"></i> Matrículas
                                            </a>

                                            <form asp-action="ToggleActivo" method="post" style="display:inline;">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm @(item.Activo ? "btn-outline-danger" : "btn-outline-success")" title="@(item.Activo ? "Desactivar" : "Activar") curso">
                                                    <i class="bi @(item.Activo ? "bi-eye-slash" : "bi-eye")"></i>
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>