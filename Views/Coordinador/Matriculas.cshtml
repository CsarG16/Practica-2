@model IEnumerable<Practica_2.Models.Matricula>

@{
    ViewData["Title"] = "Gestión de Matrículas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <div>
            <h2 class="mb-0 text-info fw-bold">
                <i class="bi bi-card-checklist me-2"></i>Matrículas del Curso
            </h2>
            <p class="text-muted fs-5 mb-0">@ViewBag.CursoNombre</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i>Volver al Panel
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4">ID Usuario</th>
                            <th>Fecha de Registro</th>
                            <th>Estado Actual</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                                    Aún no hay alumnos matriculados en este curso.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 font-monospace text-secondary small">@item.UsuarioId</td>
                                    <td>@item.FechaRegistro.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>
                                        @if (item.Estado == Practica_2.Models.MatriculaEstado.Pendiente)
                                        {
                                            <span class="badge bg-warning text-dark px-3 py-2 rounded-pill"><i class="bi bi-hourglass-split me-1"></i>Pendiente</span>
                                        }
                                        else if (item.Estado == Practica_2.Models.MatriculaEstado.Confirmada)
                                        {
                                            <span class="badge bg-success px-3 py-2 rounded-pill"><i class="bi bi-check-circle me-1"></i>Confirmada</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger px-3 py-2 rounded-pill"><i class="bi bi-x-circle me-1"></i>Cancelada</span>
                                        }
                                    </td>
                                    <td class="text-center pe-4">
                                        <div class="d-flex justify-content-center gap-2">
                                            @if (item.Estado == Practica_2.Models.MatriculaEstado.Pendiente)
                                            {
                                                <form asp-action="GestionarEstado" method="post" style="display:inline;">
                                                    <input type="hidden" name="matriculaId" value="@item.Id" />
                                                    <input type="hidden" name="nuevoEstado" value="Confirmada" />
                                                    <button type="submit" class="btn btn-sm btn-success" title="Confirmar Matrícula">
                                                        <i class="bi bi-check-lg"></i> Confirmar
                                                    </button>
                                                </form>
                                            }

                                            @if (item.Estado != Practica_2.Models.MatriculaEstado.Cancelada)
                                            {
                                                <form asp-action="GestionarEstado" method="post" style="display:inline;">
                                                    <input type="hidden" name="matriculaId" value="@item.Id" />
                                                    <input type="hidden" name="nuevoEstado" value="Cancelada" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Cancelar Matrícula">
                                                        <i class="bi bi-x-lg"></i> Cancelar
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>