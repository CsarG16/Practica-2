@model Practica_2.Models.Curso

@{
    ViewData["Title"] = "Editar Curso";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white p-3">
                    <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Editar Curso: @Model.Codigo</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditarCurso" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                        
                        <input type="hidden" asp-for="Id" />

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="Codigo" class="form-label fw-bold">Código</label>
                                <input asp-for="Codigo" class="form-control" />
                                <span asp-validation-for="Codigo" class="text-danger small"></span>
                            </div>
                            <div class="col-md-8">
                                <label asp-for="Nombre" class="form-label fw-bold">Nombre del Curso</label>
                                <input asp-for="Nombre" class="form-control" />
                                <span asp-validation-for="Nombre" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Creditos" class="form-label fw-bold">Créditos</label>
                                <input asp-for="Creditos" class="form-control" type="number" min="1" />
                                <span asp-validation-for="Creditos" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="CupoMaximo" class="form-label fw-bold">Cupo Máximo</label>
                                <input asp-for="CupoMaximo" class="form-control" type="number" min="1" />
                                <span asp-validation-for="CupoMaximo" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="HorarioInicio" class="form-label fw-bold">Hora de Inicio</label>
                                <input asp-for="HorarioInicio" class="form-control" type="time" />
                                <span asp-validation-for="HorarioInicio" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="HorarioFin" class="form-label fw-bold">Hora de Fin</label>
                                <input asp-for="HorarioFin" class="form-control" type="time" />
                                <span asp-validation-for="HorarioFin" class="text-danger small"></span>
                            </div>
                        </div>

                        <div class="form-check form-switch mb-4 fs-5">
                            <input class="form-check-input" type="checkbox" asp-for="Activo">
                            <label class="form-check-label" asp-for="Activo">Curso Activo (Visible en el catálogo)</label>
                        </div>

                        <div class="d-flex justify-content-between pt-3 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4 rounded-pill">Cancelar</a>
                            <button type="submit" class="btn btn-success px-5 rounded-pill shadow-sm">Actualizar Curso</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}